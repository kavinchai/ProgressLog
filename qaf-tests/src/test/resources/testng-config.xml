<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="WorkoutApp E2E Tests" verbose="2" parallel="false">

    <parameter name="step.provider.pkg" value="com.kavin.fitness.e2e.steps" />
    <parameter name="scenario.file.loc" value="src/test/resources/scenarios" />

    <test name="Workout Lifting Flows">
        <parameter name="scenario.file.loc" value="src/test/resources/scenarios/workout_lifting.feature" />
